{
    "name": "app/fund-transfer-api",
    "description": "Secure Fund Transfer API - Production-grade financial transaction system",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "ext-bcmath": "*",
        "ext-redis": "*",
        "symfony/framework-bundle": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/flex": "^2",
        "symfony/runtime": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/property-access": "^7.1",
        "doctrine/orm": "^3.2",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "predis/predis": "^2.3",
        "monolog/monolog": "^3.6",
        "symfony/monolog-bundle": "^3.10",
        "symfony/messenger": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3",
        "symfony/test-pack": "^1.1",
        "phpstan/phpstan": "^1.12",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-symfony": "^1.4",
        "friendsofphp/php-cs-fixer": "^3.64",
        "symfony/browser-kit": "^7.1",
        "doctrine/doctrine-fixtures-bundle": "^3.6",
        "fakerphp/faker": "^1.23"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"],
        "test": "php bin/phpunit",
        "test:unit": "php bin/phpunit --testsuite=Unit",
        "test:integration": "php bin/phpunit --testsuite=Integration",
        "analyse": "vendor/bin/phpstan analyse",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.1.*"
        }
    }
}
