APP_ENV=dev
APP_SECRET=change_this_to_a_random_string_in_production

# Database
DATABASE_URL="mysql://app:secret@db:3306/fund_transfer?serverVersion=8.0&charset=utf8mb4"

# Redis
REDIS_URL=redis://redis:6379

# API Security
API_KEY_HEADER=X-API-Key

# Rate Limiting (requests per minute per account)
RATE_LIMIT_PER_ACCOUNT=60

# Idempotency key TTL in seconds (24 hours)
IDEMPOTENCY_KEY_TTL=86400
